local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local UIS = game:GetService("UserInputService")

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "NextKillerStandalone"
screenGui.ResetOnSpawn = false
screenGui.Parent = game.CoreGui

local function EnableDrag(frame)
    local dragging = false
    local dragStart
    local startPos

    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart

            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 230, 0, 28)

-- Nyambung sama InfoGui
frame.Position = UDim2.new(0, 535, 0, 10)

frame.BackgroundColor3 = Color3.fromRGB(15,15,15)
frame.BackgroundTransparency = 0.2
frame.BorderSizePixel = 0
frame.Active = true
frame.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0,8)
corner.Parent = frame

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(255,255,255)
stroke.Transparency = 0.4
stroke.Thickness = 1
stroke.Parent = frame

local label = Instance.new("TextLabel")
label.Size = UDim2.new(1,0,1,0)
label.BackgroundTransparency = 1
label.Font = Enum.Font.GothamBold
label.TextSize = 13
label.TextStrokeTransparency = 0.8
label.TextXAlignment = Enum.TextXAlignment.Center
label.Text = "Next Killer: ..."
label.TextColor3 = Color3.fromRGB(255,80,80)
label.Parent = frame

EnableDrag(frame)

local function GetNextKillerName()
    local players = Players:GetPlayers()

    if #players == 0 then
        return "Unknown"
    end

    local sorted = {}

    for _, p in ipairs(players) do
        local allow = p:GetAttribute("AllowKiller") == true
        local chance = tonumber(p:GetAttribute("KillerChance")) or 0

        table.insert(sorted, {
            p = p,
            allow = allow,
            chance = chance
        })
    end

    table.sort(sorted, function(a,b)
        if a.allow ~= b.allow then
            return a.allow
        end

        return a.chance > b.chance
    end)

    local nk = sorted[1] and sorted[1].p

    if not nk then
        return "Unknown"
    end

    if nk == LocalPlayer then
        return "YOU"
    end

    local killerName = nk:GetAttribute("SelectedKiller")

    if killerName and killerName ~= "" then
        return tostring(killerName)
    end

    return nk.Name
end

local function Update()
    pcall(function()
        local team = LocalPlayer.Team
        local role = "Spectator"

        if team then
            if team.Name == "Killer" then
                role = "Killer"
            elseif team.Name == "Survivors" then
                role = "Survivor"
            end
        end

        if role == "Spectator" then
            local nextName = GetNextKillerName()

            label.Text = "Next Killer: " .. nextName

            label.TextColor3 =
                nextName == "YOU"
                and Color3.fromRGB(255,200,0)
                or Color3.fromRGB(255,80,80)
        else
            label.Text = "Next Killer: InMatch"
            label.TextColor3 = Color3.fromRGB(255,80,80)
        end
    end)
end

local updateTask = task.spawn(function()
    while true do
        task.wait(1)
        Update()
    end
end)

local inputConn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then
        return
    end

    if input.KeyCode == Enum.KeyCode.M then
        frame.Visible = not frame.Visible
    end
end)

screenGui.Destroying:Connect(function()
    if updateTask then
        coroutine.close(updateTask)
    end

    if inputConn then
        inputConn:Disconnect()
    end
end)

return screenGui
