local function GetNextKillerName()
    local players = Players:GetPlayers()

    if #players == 0 then
        return "Unknown"
    end

    local sorted = {}

    for _, p in ipairs(players) do
        local allow = p:GetAttribute("AllowKiller") == true
        local chance = tonumber(p:GetAttribute("KillerChance")) or 0

        table.insert(sorted,{
            p = p,
            allow = allow,
            chance = chance
        })
    end

    table.sort(sorted,function(a,b)
        if a.allow ~= b.allow then
            return a.allow
        end

        return a.chance > b.chance
    end)

    local nk = sorted[1] and sorted[1].p

    if not nk then
        return "Unknown"
    end

    if nk == LocalPlayer then
        return "YOU"
    end

    local killerName = nk:GetAttribute("SelectedKiller")

    if killerName and killerName ~= "" then
        return tostring(killerName)
    end

    return nk.Name
end

local function Update()
    pcall(function()
        local team = LocalPlayer.Team
        local role = "Spectator"

        if team then
            if team.Name == "Killer" then
                role = "Killer"
            elseif team.Name == "Survivors" then
                role = "Survivor"
            end
        end

        if role == "Spectator" then
            local nextName = GetNextKillerName()

            label.Text = "Next Killer: "..nextName

            label.TextColor3 =
                nextName == "YOU"
                and Color3.fromRGB(255,200,0)
                or Color3.fromRGB(255,80,80)
        else
            label.Text = "Next Killer: InMatch"
            label.TextColor3 = Color3.fromRGB(255,80,80)
        end
    end)
end

task.spawn(function()
    while true do
        task.wait(1)
        Update()
    end
end)

return screenGui
